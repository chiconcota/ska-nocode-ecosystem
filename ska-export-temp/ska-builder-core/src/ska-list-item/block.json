{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ska-builder/list-item",
    "version": "1.0.0",
    "title": "Ska List Item",
    "category": "ska-blocks",
    "icon": "minus",
    "description": "A single list item (li).",
    "parent": [ "ska-builder/list" ],
    "attributes": {
        "tailwindClasses": {
            "type": "string",
            "default": ""
        },
        "className": {
            "type": "string",
            "default": ""
        },
        "logic": {
            "type": "object",
            "default": {
                "enabled": false,
                "key": "",
                "operator": "==",
                "value": ""
            }
        }
    },
    "supports": {
        "html": false,
        "className": false,
        "customClassName": false
    },
    "textdomain": "ska-builder-core",
    "editorScript": "file:./index.js",
    "render": "file:./render.php"
}

