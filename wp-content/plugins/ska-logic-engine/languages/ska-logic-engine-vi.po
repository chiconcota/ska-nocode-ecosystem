msgid "Cement binds the ecosystem. "
msgstr "Xi-măng kết dính hệ sinh thái. Xử lý sự kiện (Workflows), Phân giải ngữ cảnh (Smart Context), CodeMirror UI và SkaFX AST."

msgid "Cancel"
msgstr "Hủy"

msgid "Created date (created_at)"
msgstr "Ngày tạo (created_at)"

msgid "🧰 Data Format (Junk Standardization)"
msgstr "🧰 Định Dạng Dữ Liệu (Chuẩn hóa Rác)"

