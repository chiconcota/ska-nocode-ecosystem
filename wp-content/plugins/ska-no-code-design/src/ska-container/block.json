{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ska-builder/container",
    "version": "1.0.0",
    "title": "Ska Container",
    "category": "ska-atomic",
    "icon": "layout",
    "description": "A div/section wrapper that supports Tailwind classes and nested blocks.",
    "attributes": {
        "tagName": {
            "type": "string",
            "default": "div"
        },
        "tailwindClasses": {
            "type": "string",
            "default": ""
        },
        "className": {
            "type": "string",
            "default": ""
        },
        "logic": {
            "type": "object",
            "default": {
                "enabled": false,
                "key": "",
                "operator": "==",
                "value": ""
            }
        },
        "isSkaForm": {
            "type": "boolean",
            "default": false
        },
        "formActionId": {
            "type": "string",
            "default": ""
        },
        "usePersist": {
            "type": "boolean",
            "default": false
        },
        "templateLock": {
            "type": "string",
            "default": "false"
        }
    },
    "supports": {
        "html": false,
        "customClassName": true,
        "align": [
            "wide",
            "full"
        ]
    },
    "textdomain": "ska-builder-core",
    "editorScript": "file:./index.js",
    "render": "file:./render.php"
}