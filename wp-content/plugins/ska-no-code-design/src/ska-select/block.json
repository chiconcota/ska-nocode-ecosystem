{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ska-builder/select",
    "version": "1.0.0",
    "title": "Ska Select",
    "category": "ska-atomic",
    "icon": "menu",
    "description": "Atomic select (dropdown) block for Ska Forms.",
    "attributes": {
        "fieldName": {
            "type": "string",
            "default": "my_select"
        },
        "optionsText": {
            "type": "string",
            "default": "Option 1:opt1\nOption 2:opt2"
        },
        "isRequired": {
            "type": "boolean",
            "default": false
        },
        "isMultiple": {
            "type": "boolean",
            "default": false
        },
        "displayStyle": {
            "type": "string",
            "default": "dropdown"
        },
        "tailwindClasses": {
            "type": "string",
            "default": ""
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "supports": {
        "html": false,
        "customClassName": true
    },
    "textdomain": "ska-builder-core",
    "editorScript": "file:./index.js",
    "render": "file:./render.php"
}