{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ska-builder/form-rich-text",
    "version": "1.0.0",
    "title": "Ska Rich Text",
    "category": "ska-atomic",
    "icon": "edit",
    "description": "Rich text editor block using Shadow Scratchpad for Ska Forms.",
    "attributes": {
        "field": {
            "type": "string",
            "default": "noi_dung"
        },
        "label": {
            "type": "string",
            "default": "Nội dung"
        },
        "tailwindClasses": {
            "type": "string",
            "default": ""
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "supports": {
        "html": false,
        "customClassName": true
    },
    "textdomain": "ska-builder-core",
    "editorScript": "file:./index.js",
    "render": "file:./render.php"
}