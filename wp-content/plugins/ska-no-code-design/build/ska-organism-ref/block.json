{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ska-builder/organism-ref",
  "version": "1.0.0",
  "title": "Ska Symbol Reference",
  "category": "ska-organisms",
  "icon": "superhero",
  "description": "Tham chiếu tới một Ska Organism (Symbol) đã được lưu trữ.",
  "attributes": {
    "organismId": {
      "type": "string"
    },
    "skaDynamicBinding": {
      "type": "object",
      "default": {
        "script": ""
      }
    },
    "htmlAttributes": {
      "type": "array",
      "default": []
    },
    "logic": {
      "type": "object",
      "default": {
        "enabled": false,
        "key": "",
        "operator": "==",
        "value": ""
      }
    },
    "isSkaForm": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "customClassName": false
  },
  "textdomain": "ska-no-code-design",
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}