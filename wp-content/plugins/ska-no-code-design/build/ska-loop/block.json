{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ska-builder/loop",
  "version": "1.0.0",
  "title": "Ska Query Loop",
  "category": "ska-organisms",
  "icon": "update",
  "description": "Vòng lặp vạn năng siêu tốc dùng để query dữ liệu từ flat tables.",
  "attributes": {
    "sourceTable": {
      "type": "string",
      "default": ""
    },
    "limit": {
      "type": "number",
      "default": 10
    },
    "filters": {
      "type": "array",
      "default": []
    },
    "slots": {
      "type": "array",
      "default": []
    },
    "htmlAttributes": {
      "type": "array",
      "default": []
    }
  },
  "supports": {
    "html": false,
    "customClassName": false
  },
  "textdomain": "ska-no-code-design",
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}