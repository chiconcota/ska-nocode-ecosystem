{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ska-builder/form",
    "version": "1.0.0",
    "title": "Ska Form Container",
    "category": "ska-atomic",
    "icon": "feedback",
    "description": "Form wrapper that intercepts submit and sends payload to specific action URLs or Ska Logic Engine.",
    "attributes": {
        "actionName": {
            "type": "string",
            "default": "default_form_submit"
        },
        "formMethod": {
            "type": "string",
            "default": "POST"
        },
        "formAction": {
            "type": "string",
            "default": ""
        },
        "tailwindClasses": {
            "type": "string",
            "default": ""
        },
        "className": {
            "type": "string",
            "default": ""
        },
        "customStyle": {
            "type": "string",
            "default": ""
        }
    },
    "supports": {
        "html": false,
        "customClassName": true
    },
    "textdomain": "ska-builder-core",
    "editorScript": "file:./index.js",
    "render": "file:./render.php"
}
