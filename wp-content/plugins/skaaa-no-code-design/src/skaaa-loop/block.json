{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "skaaaaa-builder/loop",
	"version": "1.0.0",
	"title": "Skaaa Query Loop",
	"category": "skaaa-organisms",
	"icon": "update",
	"description": "Vòng lặp vạn năng siêu tốc dùng để query dữ liệu từ flat tables.",
	"attributes": {
		"tailwindClasses": {
			"type": "string",
			"default": ""
		},
		"sourceTable": {
			"type": "string",
			"default": ""
		},
		"limit": {
			"type": "number",
			"default": 10
		},
		"filters": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"column": { "type": "string" },
					"operator": { "type": "string" },
					"value": { "type": "string" }
				}
			},
			"default": []
		},
		"slots": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"organismId": { "type": "string" },
					"condition": { "type": "string" }
				}
			},
			"default": []
		},
		"htmlAttributes": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"key": { "type": "string" },
					"value": { "type": "string" }
				}
			},
			"default": []
		},
		"skaaaDynamicBinding": {
			"type": "object",
			"default": {
				"script": ""
			}
		}
	},
	"supports": {
		"html": false,
		"customClassName": false
	},
	"textdomain": "skaaa-no-code-design",
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
