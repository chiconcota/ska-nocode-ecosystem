{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ska-builder/icon",
  "version": "1.0.1",
  "title": "Ska Icon",
  "category": "common",
  "icon": "star-filled",
  "description": "A Material Icon block with JIT Tailwind support.",
  "attributes": {
    "iconName": {
      "type": "string",
      "default": "star"
    },
    "tailwindClasses": {
      "type": "string",
      "default": "material-icons-outlined"
    },
    "className": {
      "type": "string",
      "default": ""
    },
    "logic": {
      "type": "object",
      "default": {
        "enabled": false,
        "key": "",
        "operator": "==",
        "value": ""
      }
    }
  },
  "supports": {
    "html": false,
    "customClassName": false
  },
  "textdomain": "ska-builder-core",
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}